DEBUG=True
SECRET_KEY=change-me-in-production

# Local Docker Postgres (see repo docker-compose.yml):
DATABASE_URL=postgresql://vaultclub:vaultclub@localhost:5432/vaultclub

# Production: deploy via repo-root render.yaml (Blueprint → vaultclub-db + vaultclub-api).
# DATABASE_URL is set automatically on Render. For local access to hosted DB only,
# copy the External Database URL from the Render dashboard:
# DATABASE_URL=postgresql://...@....render.com/vaultclub?sslmode=require

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

FRONTEND_URL=http://localhost:3000

# Production (Render): DEBUG=False, SECRET_KEY from Render, DATABASE_URL from Postgres.
# Do not run seed_demo on production — use createsuperuser + /admin/ instead.
